{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "numberOfRuns": 3,
      "url": ["http://localhost/"]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
